<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="styles"/>
    <body>
        <referenceContainer name="content">
            <block class="Etechflow\Sitemap\Block\Adminhtml\UpdateNotice"
                   name="etechflow_rs_update_notice_gate"
                   template="Etechflow_Sitemap::update-notice.phtml"
                   cacheable="false"
                   before="-"/>
            <block class="Magento\Backend\Block\Template"
                   name="etechflow.sitemap.license.gate"
                   template="Etechflow_Sitemap::license/gate.phtml"/>
        </referenceContainer>
    </body>
</page>
